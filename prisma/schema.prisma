// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ── ROLES Y PERMISOS DINÁMICOS ──────────────────────────────────────────────

model Role {
  id          Int              @id @default(autoincrement())
  name        String           @unique // Ej: "Administrador", "Almacenista"
  description String?
  users       User[]
  permissions RolePermission[]

  @@map("roles")
}

model Module {
  id          Int              @id @default(autoincrement())
  name        String // Ej: "Productos", "Almacenes"
  code        String           @unique // Ej: "PRODUCTS", "WAREHOUSES"
  permissions RolePermission[]

  @@map("modules")
}

model RolePermission {
  id       Int    @id @default(autoincrement())
  roleId   Int    @map("role_id")
  role     Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)
  moduleId Int    @map("module_id")
  module   Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  // Banderas CRUD granulares (Matriz)
  canCreate Boolean @default(false) @map("can_create")
  canRead   Boolean @default(false) @map("can_read")
  canUpdate Boolean @default(false) @map("can_update")
  canDelete Boolean @default(false) @map("can_delete")

  // Un rol solo puede tener una configuración por cada módulo
  @@unique([roleId, moduleId])
  @@map("role_permissions")
}

// ── USUARIOS ───────────────────────────────────────────────────────────────

model User {
  id           Int     @id @default(autoincrement())
  cedula       String  @unique
  name         String
  passwordHash String  @map("password_hash")
  active       Boolean @default(true)

  // Relación obligatoria: Todo usuario debe tener un Rol
  roleId Int  @map("role_id")
  role   Role @relation(fields: [roleId], references: [id])

  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")
  auditLogs AuditLog[]

  // Relaciones inversas (Transacciones y Notificaciones)
  createdTransactions  Transaction[]  @relation("CreatedBy")
  approvedTransactions Transaction[]  @relation("ApprovedBy")
  notifications        Notification[]

  @@map("users")
}

// ---- Audotorial de cambios (opcional) ----
model AuditLog {
  id        Int      @id @default(autoincrement())
  //Quien hizo la Accion (Opcional, porque algunas Acciones Automaticas del sistema no tienen USuarios)
  userId    Int?     @map("user_id")
  user      User?    @relation(fields: [userId], references: [id])
  action    String // Ej: "Login", "Crear Producto", "Eliminar Almacen"
  entity    String // Ej: "Producto", "Almacen"
  entityId  Int?     @map("entity_id")
  // ID del Producto o Almacen afectado (opcional)
  details   String?  @db.Text // Detalles adicionales (JSON stringificado, por ejemplo)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("audit_logs")
}

// ── PROVEEDORES ────────────────────────────────────────────────────────────

model Supplier {
  id          Int      @id @default(autoincrement())
  document    String   @unique // RIF, RUT, NIT, etc.
  name        String
  address     String?
  phone       String?
  email       String?
  active      Boolean  @default(true)

  transactions Transaction[] // Historial de compras a este proveedor

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("suppliers")
}

// ── INVENTARIO: CATÁLOGO ───────────────────────────────────────────────────

model Category {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  description String?
  active      Boolean   @default(true)
  products    Product[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("categories")
}

model Unit {
  id           Int       @id @default(autoincrement())
  name         String    // Ej: "Kilogramos", "Litros"
  abbreviation String    @unique // Ej: "KG", "L", "UN"
  active       Boolean   @default(true)
  products     Product[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("units")
}

model Product {
  id           Int      @id @default(autoincrement())
  code         String   @unique // Código de barras o SKU interno
  name         String
  description  String?
  categoryId   Int      @map("category_id")
  category     Category @relation(fields: [categoryId], references: [id])
  unitId       Int      @map("unit_id")
  unit         Unit     @relation(fields: [unitId], references: [id])
  minimumStock Decimal  @default(0) @map("minimum_stock") @db.Decimal(10, 2)
  maximumStock Decimal? @map("maximum_stock") @db.Decimal(10, 2)
  isPerishable Boolean  @default(false) @map("is_perishable")
  active       Boolean  @default(true)

  stocks Stock[]
  transactionDetails TransactionDetail[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("products")
}

// ── INVENTARIO: ESPACIOS Y STOCK ───────────────────────────────────────────

enum WarehouseType {
  CENTRAL
  LOCAL
}

model Warehouse {
  id          Int           @id @default(autoincrement())
  name        String        @unique
  type        WarehouseType @default(LOCAL)
  location    String?
  active      Boolean       @default(true)
  
  stocks      Stock[]
  
  // Relaciones inversas
  outgoingTransactions Transaction[] @relation("SourceWarehouse")
  incomingTransactions Transaction[] @relation("DestinationWarehouse")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("warehouses")
}

model Stock {
  id          Int       @id @default(autoincrement())
  warehouseId Int       @map("warehouse_id")
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])
  productId   Int       @map("product_id")
  product     Product   @relation(fields: [productId], references: [id])
  quantity    Decimal   @default(0) @db.Decimal(10, 2)

  updatedAt DateTime @updatedAt @map("updated_at")

  // Un producto solo tiene un registro de stock por almacén
  @@unique([warehouseId, productId])
  @@map("stocks")
}

// ── FASE 2: MOTOR TRANSACCIONAL Y SOCKETS ──────────────────────────────────

enum TransactionType {
  RECEPTION    // Entrada por compra (Carga Excel o Manual)
  TRANSFER     // Envío de Central a Local
  ADJUSTMENT   // Ajuste manual de inventario
}

enum TransactionStatus {
  DRAFT        // Borrador (Se está editando, no avisa a nadie)
  PENDING      // Pendiente de Aprobación (Avisa a Gerentes)
  APPROVED     // Aprobado por Gerente (Avisa al almacenista que puede confirmar)
  REJECTED     // Rechazado por Gerente
  CONFIRMED    // Confirmado físicamente (ACTUALIZA EL STOCK REAL)
}

model Transaction {
  id          Int               @id @default(autoincrement())
  type        TransactionType
  status      TransactionStatus @default(DRAFT)
  
  // Origen y Destino (Son opcionales porque una Recepción no tiene origen interno)
  sourceId    Int?              @map("source_id")
  source      Warehouse?        @relation("SourceWarehouse", fields: [sourceId], references: [id])
  
  destinationId Int?            @map("destination_id")
  destination   Warehouse?      @relation("DestinationWarehouse", fields: [destinationId], references: [id])
  
  // Proveedor (Solo para Recepciones)
  supplierId  Int?              @map("supplier_id")
  supplier    Supplier?         @relation(fields: [supplierId], references: [id])

  // Seguimiento de Usuarios
  createdById Int               @map("created_by_id")
  createdBy   User              @relation("CreatedBy", fields: [createdById], references: [id])
  
  approvedById Int?             @map("approved_by_id")
  approvedBy   User?            @relation("ApprovedBy", fields: [approvedById], references: [id])

  notes       String?           @db.Text
  
  details     TransactionDetail[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("transactions")
}

model TransactionDetail {
  id            Int         @id @default(autoincrement())
  transactionId Int         @map("transaction_id")
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  
  productId     Int         @map("product_id")
  product       Product     @relation(fields: [productId], references: [id])

  quantity      Decimal     @db.Decimal(10, 2)
  unitPrice     Decimal     @default(0) @map("unit_price") @db.Decimal(10, 2) // Precio exacto sin afectar el producto maestro
  
  expirationDate DateTime?  @map("expiration_date") @db.Date // Lote de vencimiento opcional

  @@map("transaction_details")
}

// ── SISTEMA DE NOTIFICACIONES PUSH ─────────────────────────────────────────

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id") // A quién va dirigida
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  title     String
  message   String
  isRead    Boolean  @default(false) @map("is_read")
  
  // Para saber a qué pantalla redirigir cuando hacen clic en la campana
  link      String?  

  createdAt DateTime @default(now()) @map("created_at")

  @@map("notifications")
}
