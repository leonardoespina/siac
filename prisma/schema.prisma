// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ── ROLES Y PERMISOS DINÁMICOS ──────────────────────────────────────────────

model Role {
  id          Int              @id @default(autoincrement())
  name        String           @unique // Ej: "Administrador", "Almacenista"
  description String?
  isGlobal    Boolean          @default(false) @map("is_global")
  users       User[]
  permissions RolePermission[]

  @@map("roles")
}

model Module {
  id          Int              @id @default(autoincrement())
  name        String // Ej: "Productos", "Almacenes"
  code        String           @unique // Ej: "PRODUCTS", "WAREHOUSES"
  permissions RolePermission[]

  @@map("modules")
}

model RolePermission {
  id       Int    @id @default(autoincrement())
  roleId   Int    @map("role_id")
  role     Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)
  moduleId Int    @map("module_id")
  module   Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  // Banderas CRUD granulares (Matriz)
  canCreate Boolean @default(false) @map("can_create")
  canRead   Boolean @default(false) @map("can_read")
  canUpdate Boolean @default(false) @map("can_update")
  canDelete Boolean @default(false) @map("can_delete")

  // Un rol solo puede tener una configuración por cada módulo
  @@unique([roleId, moduleId])
  @@map("role_permissions")
}

// ── USUARIOS ───────────────────────────────────────────────────────────────

model User {
  id           Int     @id @default(autoincrement())
  cedula       String  @unique
  name         String
  passwordHash String  @map("password_hash")
  active       Boolean @default(true)

  // Relación obligatoria: Todo usuario debe tener un Rol
  roleId Int  @map("role_id")
  role   Role @relation(fields: [roleId], references: [id])

  // Aislamiento por Almacén Local
  warehouseId Int?       @map("warehouse_id")
  warehouse   Warehouse? @relation(fields: [warehouseId], references: [id])

  // Aislamiento por Comedor
  diningRoomId Int?      @map("dining_room_id")
  diningRoom   DiningRoom? @relation(fields: [diningRoomId], references: [id])

  // Aislamiento por Dependencia (Para Gerentes, Autoridad sobre todas las subdependencias)
  dependencyId Int?           @map("dependency_id")
  dependency   Dependency?    @relation(fields: [dependencyId], references: [id])

  // Aislamiento por Subdependencia (Para Solicitantes/Aprobadores de Comensales)
  subdependencyId Int?           @map("subdependency_id")
  subdependency   Subdependency? @relation(fields: [subdependencyId], references: [id])

  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")
  auditLogs AuditLog[]

  // Relaciones inversas (Transacciones y Notificaciones)
  createdTransactions  Transaction[]  @relation("CreatedBy")
  approvedTransactions Transaction[]  @relation("ApprovedBy")
  notifications        Notification[]
  shifts               Shift[]

  createdDinerRequests  DinerRequest[] @relation("DinerRequestsCreated")
  approvedDinerRequests DinerRequest[] @relation("DinerRequestsApproved")

  @@map("users")
}

// ---- Audotorial de cambios (opcional) ----
model AuditLog {
  id        Int      @id @default(autoincrement())
  //Quien hizo la Accion (Opcional, porque algunas Acciones Automaticas del sistema no tienen USuarios)
  userId    Int?     @map("user_id")
  user      User?    @relation(fields: [userId], references: [id])
  action    String // Ej: "Login", "Crear Producto", "Eliminar Almacen"
  entity    String // Ej: "Producto", "Almacen"
  entityId  Int?     @map("entity_id")
  // ID del Producto o Almacen afectado (opcional)
  details   String?  @db.Text // Detalles adicionales (JSON stringificado, por ejemplo)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("audit_logs")
}

// ── PROVEEDORES ────────────────────────────────────────────────────────────

model Supplier {
  id          Int      @id @default(autoincrement())
  document    String   @unique // RIF, RUT, NIT, etc.
  name        String
  address     String?
  phone       String?
  email       String?
  active      Boolean  @default(true)

  transactions Transaction[] // Historial de compras a este proveedor

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("suppliers")
}

// ── INSTITUCIONES (APOYOS Y DONACIONES) ────────────────────────────────────

model Institution {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  type        String?  // Ej: "Educativa", "Salud", "Comunitaria", "Gubernamental"
  description String?
  active      Boolean  @default(true)

  transactions Transaction[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("institutions")
}

// ── INVENTARIO: CATÁLOGO ───────────────────────────────────────────────────

model Category {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  description String?
  active      Boolean   @default(true)
  products    Product[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("categories")
}

model Unit {
  id           Int       @id @default(autoincrement())
  name         String    // Ej: "Kilogramos", "Litros"
  abbreviation String    @unique // Ej: "KG", "L", "UN"
  active       Boolean   @default(true)
  products     Product[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("units")
}

model Product {
  id           Int      @id @default(autoincrement())
  code         String   @unique // Código de barras o SKU interno
  name         String
  description  String?
  categoryId   Int      @map("category_id")
  category     Category @relation(fields: [categoryId], references: [id])
  unitId       Int      @map("unit_id")
  unit         Unit     @relation(fields: [unitId], references: [id])
  minimumStock Decimal  @default(0) @map("minimum_stock") @db.Decimal(10, 2)
  maximumStock Decimal? @map("maximum_stock") @db.Decimal(10, 2)
  referencePrice Decimal @default(0) @map("reference_price") @db.Decimal(10, 2) // Precio base para cálculo de reportes
  isPerishable Boolean  @default(false) @map("is_perishable")
  active       Boolean  @default(true)

  stocks Stock[]
  transactionDetails TransactionDetail[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("products")
}

// ── INVENTARIO: ESPACIOS Y STOCK ───────────────────────────────────────────

enum WarehouseType {
  CENTRAL
  LOCAL
}

model Warehouse {
  id          Int           @id @default(autoincrement())
  name        String        @unique
  type        WarehouseType @default(LOCAL)
  location    String?
  active      Boolean       @default(true)
  
  stocks      Stock[]
  
  // Relaciones inversas
  outgoingTransactions Transaction[] @relation("SourceWarehouse")
  incomingTransactions Transaction[] @relation("DestinationWarehouse")
  users                User[]
  shifts               Shift[]
  diningRooms          DiningRoom[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("warehouses")
}

model Stock {
  id          Int       @id @default(autoincrement())
  warehouseId Int       @map("warehouse_id")
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])
  productId   Int       @map("product_id")
  product     Product   @relation(fields: [productId], references: [id])
  quantity    Decimal   @default(0) @db.Decimal(10, 2)

  updatedAt DateTime @updatedAt @map("updated_at")

  // Un producto solo tiene un registro de stock por almacén
  @@unique([warehouseId, productId])
  @@map("stocks")
}

// ── FASE 2: MOTOR TRANSACCIONAL Y SOCKETS ──────────────────────────────────

enum TransactionType {
  RECEPTION    // Entrada por compra (Carga Excel o Manual)
  TRANSFER     // Envío de Central a Local
  ADJUSTMENT   // Ajuste manual de inventario
  CONSUMPTION  // Despacho/Consumo diario de cocina
  LOSS         // Merma o pérdida
  SUPPORT      // Apoyo o Donación a Institución
}

enum TransactionStatus {
  DRAFT        // Borrador (Se está editando, no avisa a nadie)
  PENDING      // Pendiente de Aprobación (Avisa a Gerentes)
  APPROVED     // Aprobado por Gerente (Avisa al almacenista que puede confirmar)
  REJECTED     // Rechazado por Gerente
  CONFIRMED    // Confirmado físicamente (ACTUALIZA EL STOCK REAL)
}

model Transaction {
  id          Int               @id @default(autoincrement())
  type        TransactionType
  status      TransactionStatus @default(DRAFT)
  
  // Origen y Destino (Son opcionales porque una Recepción no tiene origen interno)
  sourceId    Int?              @map("source_id")
  source      Warehouse?        @relation("SourceWarehouse", fields: [sourceId], references: [id])
  
  destinationId Int?            @map("destination_id")
  destination   Warehouse?      @relation("DestinationWarehouse", fields: [destinationId], references: [id])
  
  // Proveedor (Solo para Recepciones)
  supplierId  Int?              @map("supplier_id")
  supplier    Supplier?         @relation(fields: [supplierId], references: [id])

  // Institución (Solo para Apoyos/Donaciones)
  institutionId Int?            @map("institution_id")
  institution   Institution?    @relation(fields: [institutionId], references: [id])

  // Seguimiento de Usuarios
  createdById Int               @map("created_by_id")
  createdBy   User              @relation("CreatedBy", fields: [createdById], references: [id])
  
  approvedById Int?             @map("approved_by_id")
  approvedBy   User?            @relation("ApprovedBy", fields: [approvedById], references: [id])

  // Vinculación con el Turno (Para consumos y mermas locales)
  shiftId     Int?              @map("shift_id")
  shift       Shift?            @relation(fields: [shiftId], references: [id])

  referenceNumber String?         @map("reference_number") // Número de factura, guía de despacho o nota de entrega
  notes       String?           @db.Text
  
  details     TransactionDetail[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("transactions")
}

// ── CONTROL DE TURNOS (OPERACIÓN LOCAL) ────────────────────────────────────

model Shift {
  id          Int       @id @default(autoincrement())
  warehouseId Int       @map("warehouse_id")
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])
  userId      Int       @map("user_id")
  user        User      @relation(fields: [userId], references: [id])
  startTime   DateTime  @default(now()) @map("start_time")
  endTime     DateTime? @map("end_time")
  status      String    @default("OPEN") // 'OPEN' o 'CLOSED'
  shiftType   String    @default("DIURNO") @map("shift_type") // 'DIURNO' | 'NOCTURNO'
  notes       String?   @db.Text

  transactions Transaction[]

  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@map("shifts")
}

model TransactionDetail {
  id            Int         @id @default(autoincrement())
  transactionId Int         @map("transaction_id")
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  
  productId     Int         @map("product_id")
  product       Product     @relation(fields: [productId], references: [id])

  quantity      Decimal     @db.Decimal(10, 2)
  expectedQuantity Decimal? @map("expected_quantity") @db.Decimal(10, 2)
  
  unitPrice     Decimal     @default(0) @map("unit_price") @db.Decimal(10, 2) // Precio exacto sin afectar el producto maestro
  
  expirationDate DateTime?  @map("expiration_date") @db.Date // Lote de vencimiento opcional
  
  discrepancyReason String? @map("discrepancy_reason") @db.VarChar(255)

  @@map("transaction_details")
}

// ── SISTEMA DE NOTIFICACIONES PUSH ─────────────────────────────────────────

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id") // A quién va dirigida
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  title     String
  message   String
  isRead    Boolean  @default(false) @map("is_read")
  
  // Para saber a qué pantalla redirigir cuando hacen clic en la campana
  link      String?  

  createdAt DateTime @default(now()) @map("created_at")

  @@map("notifications")
}

// ── MÓDULO COMENSALES (ESTRUCTURA ORGANIZACIONAL) ─────────────────────────

model DiningRoom {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  active      Boolean   @default(true)
  
  // Un comedor saca sus insumos de un almacén o cocina
  warehouseId Int?      @map("warehouse_id")
  warehouse   Warehouse? @relation(fields: [warehouseId], references: [id])
  
  diners        Diner[]
  dinerRequests DinerRequest[]
  users         User[]

  @@map("dining_rooms")
}

model Dependency {
  id              Int             @id @default(autoincrement())
  name            String          @unique
  active          Boolean         @default(true)
  subdependencies Subdependency[]
  users           User[]
  
  @@map("dependencies")
}

model Subdependency {
  id            Int        @id @default(autoincrement())
  name          String
  active        Boolean    @default(true)
  dependencyId  Int        @map("dependency_id")
  dependency    Dependency @relation(fields: [dependencyId], references: [id])
  
  users         User[]    
  diners        Diner[]   

  @@map("subdependencies")
}

model Squad {
  id     Int     @id @default(autoincrement())
  name   String  @unique
  active Boolean @default(true)
  
  diners Diner[]       

  @@map("squads")
}

model Position {
  id     Int     @id @default(autoincrement())
  name   String  @unique
  active Boolean @default(true)
  
  diners Diner[]

  @@map("positions")
}

model Diner {
  id          Int     @id @default(autoincrement())
  cedula      String  @unique
  name        String
  rationType  String  @default("NORMAL") @map("ration_type") // NORMAL o DIETA
  active      Boolean @default(true)
  
  // A qué subdependencia/área pertenece el trabajador
  subdependencyId Int           @map("subdependency_id")
  subdependency   Subdependency @relation(fields: [subdependencyId], references: [id])

  // A qué cuadrilla/turno (catálogo base) está asignado
  squadId     Int     @map("squad_id")
  squad       Squad   @relation(fields: [squadId], references: [id])
  
  // Cargo o puesto del trabajador (opcional por retrocompatibilidad)
  positionId  Int?    @map("position_id")
  position    Position? @relation(fields: [positionId], references: [id])
  
  // Comedor Base asignado al trabajador
  diningRoomId Int?       @map("dining_room_id")
  diningRoom   DiningRoom? @relation(fields: [diningRoomId], references: [id])
  
  fingerprint String? @db.Text
  qrCode      String? @unique @map("qr_code")

  requestDetails DinerRequestDetail[]

  @@map("diners")
}

model DinerRequest {
  id        Int      @id @default(autoincrement())
  date      DateTime @db.Date
  shiftType String   @map("shift_type")  // DESAYUNO, ALMUERZO, CENA, SOBRECENA
  status    String   @default("PENDING") // PENDING, APPROVED, REJECTED
  
  createdById Int   @map("created_by_id")
  createdBy   User  @relation(name: "DinerRequestsCreated", fields: [createdById], references: [id])
  
  approvedById Int? @map("approved_by_id")
  approvedBy   User? @relation(name: "DinerRequestsApproved", fields: [approvedById], references: [id])

  diningRoomId Int?       @map("dining_room_id")
  diningRoom   DiningRoom? @relation(fields: [diningRoomId], references: [id])

  details DinerRequestDetail[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("diner_requests")
}

model DinerRequestDetail {
  id        Int    @id @default(autoincrement())
  requestId Int    @map("request_id")
  request   DinerRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  
  dinerId   Int    @map("diner_id")
  diner     Diner  @relation(fields: [dinerId], references: [id])
  
  rationType String @default("NORMAL") @map("ration_type")

  @@unique([requestId, dinerId])
  @@map("diner_request_details")
}
